# =============================================================================
# Discord File Bot — Environment Configuration
# Copy this file to .env and fill in your values (NEVER commit .env!)
# =============================================================================

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Bot Owner Discord User IDs (comma-separated, e.g. 123456789,987654321)
# These users bypass restrictions and can use all admin commands.
OWNER_IDS=

# ─── OPTIONAL ───────────────────────────────────────────────────────────────

# Command prefix (default: !)
COMMAND_PREFIX=!

# Max file size in MB (default: 500)
# Discord Nitro Classic = 50 MB, Discord Nitro = 500 MB
MAX_FILE_SIZE_MB=500

# Cooldown between commands in seconds (default: 3)
COOLDOWN_SECONDS=3

# Max files per command (default: 10)
MAX_FILES_PER_COMMAND=10

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Port for health-check server (Railway will override this automatically)
PORT=8080

# Log Channel ID (optional)
# The bot will send a notification to this channel when a user opens/replies to a DM.
# Right-click a channel → Copy Channel ID (requires Developer Mode).
LOG_CHANNEL_ID=
